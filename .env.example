# ─── Discord ───────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Your Discord user ID — the only person the bot takes orders from / DMs
OWNER_ID=
# Optional: guild ID for instant command registration during dev
DEV_GUILD_ID=
# Channel ID where the new-limiteds feed is posted
FEED_CHANNEL_ID=

# ─── Database (Railway Postgres) ───────────────────────────
DATABASE_URL=

# ─── Roblox ────────────────────────────────────────────────
# .ROBLOSECURITY cookie (the full value, including the _|WARNING:... prefix)
ROBLOSECURITY=
# Roblox user ID of the buying account
ROBLOX_USER_ID=

# ─── Tuning (optional — sensible defaults applied) ─────────
# Poll interval base in seconds (jitter is applied on top)
POLL_INTERVAL_SECONDS=15
# Daily approval ping time, 24h GMT
DAILY_APPROVAL_HOUR_GMT=10
